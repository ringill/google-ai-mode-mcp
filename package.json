{
  "name": "google-ai-mode-mcp",
  "version": "1.0.1",
  "description": "MCP server for Google AI Search Mode with CAPTCHA handling. Free, token-efficient web research with source citations.",
  "type": "module",
  "bin": {
    "google-ai-mode-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "watch": "tsc --watch",
    "dev": "tsx watch src/index.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google",
    "google-ai-mode",
    "ai-search",
    "web-research",
    "claude",
    "claude-code",
    "citations",
    "browser-automation",
    "patchright",
    "cursor",
    "cline",
    "windsurf"
  ],
  "author": "Gérôme Dexheimer <hello@geromedexheimer.de> (https://github.com/PleasePrompto)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PleasePrompto/google-ai-mode-mcp.git"
  },
  "homepage": "https://github.com/PleasePrompto/google-ai-mode-mcp#readme",
  "bugs": {
    "url": "https://github.com/PleasePrompto/google-ai-mode-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.0",
    "env-paths": "^3.0.0",
    "patchright": "^1.48.2",
    "turndown": "^7.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
