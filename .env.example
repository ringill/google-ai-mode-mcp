# Google AI Search Mode MCP Server Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# AUTHENTICATION (Optional - for CAPTCHA-free operation)
# =============================================================================
# To avoid CAPTCHA, you can pre-extract Google cookies from your browser:
#
# 1. Open Chrome/Edge and log in to your Google account
# 2. Go to https://www.google.com/search?udm=50&q=test
# 3. Press F12 (DevTools) → Application → Cookies → https://www.google.com
# 4. Copy the cookies in JSON format or key=value format
#
# Method A - JSON format (recommended):
# GOOGLE_AI_COOKIES={"AEC":"your_aec_value","SIDCC":"your_sidcc_value","NID":"..."}
#
# Method B - Key=value format (one per line or semicolon separated):
# GOOGLE_AI_COOKIES=AEC=your_aec_value; SIDCC=your_sidcc_value; NID=your_nid_value
#
# Required cookies for authentication: AEC, SIDCC, SID, NID
# Optional cookies: HSID, SSID, APISID, SAPISID, 1P_JAR, CONSENT, SOCS
#
# Note: Cookies expire periodically. If CAPTCHA reappears, extract fresh cookies.

# =============================================================================
# BROWSER SETTINGS
# =============================================================================
GOOGLE_AI_HEADLESS=true                   # Run browser in headless mode
GOOGLE_AI_BROWSER_TIMEOUT=30000           # Browser timeout in ms (30 seconds)

# =============================================================================
# STEALTH SETTINGS
# =============================================================================
GOOGLE_AI_STEALTH_ENABLED=true            # Enable stealth mode
GOOGLE_AI_STEALTH_RANDOM_DELAYS=true      # Random delays between actions
GOOGLE_AI_STEALTH_HUMAN_TYPING=true       # Human-like typing
GOOGLE_AI_STEALTH_MOUSE_MOVEMENTS=true    # Human-like mouse movements
GOOGLE_AI_TYPING_WPM_MIN=160              # Minimum typing speed (WPM)
GOOGLE_AI_TYPING_WPM_MAX=240              # Maximum typing speed (WPM)
GOOGLE_AI_MIN_DELAY_MS=100                # Minimum delay between actions (ms)
GOOGLE_AI_MAX_DELAY_MS=400                # Maximum delay between actions (ms)

# =============================================================================
# CAPTCHA SETTINGS
# =============================================================================
GOOGLE_AI_CAPTCHA_TIMEOUT=300000          # CAPTCHA timeout in ms (5 minutes)
GOOGLE_AI_CAPTCHA_POLL_INTERVAL=3000      # CAPTCHA polling interval (3 seconds)
GOOGLE_AI_CAPTCHA_MAX_CONSECUTIVE=3       # Max consecutive CAPTCHAs before browser restart
GOOGLE_AI_CAPTCHA_COOLDOWN_MS=30000       # Cooldown after browser restart (30 seconds)

# =============================================================================
# SEARCH SETTINGS
# =============================================================================
GOOGLE_AI_RESPONSE_TIMEOUT=30000          # Search response timeout in ms (30 seconds)
GOOGLE_AI_CITATION_TIMEOUT=5000           # Citation extraction timeout (5 seconds)

# =============================================================================
# PATHS (Optional)
# =============================================================================
# GOOGLE_AI_PROFILE_DIR=/custom/path/to/profile   # Optional: Custom browser profile directory
